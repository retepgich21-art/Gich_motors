body{

font-family:Arial;
background:#f4f4f4;
text-align:center;
}

header{

background:#333;
color:white;
padding:20px;

}

nav a{

color:white;
margin:10px;
text-decoration:none;

}

#car-list{

display:flex;
flex-wrap:wrap;
justify-content:center;
gap:20px;

}

.car{

background:white;
padding:15px;
width:250px;
box-shadow:0 0 5px gray;

}

.car img{

width:100%;

}

form input{

display:block;
margin:10px auto;
padding:10px;
width:200px;

}

button{

padding:10px 20px;

}
